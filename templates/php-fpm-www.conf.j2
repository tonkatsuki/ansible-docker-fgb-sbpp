[www]
user = app
group = app

listen = {{ php_fpm_listen }}
listen.owner = app
listen.group = app
listen.mode = 0660

pm = dynamic
pm.max_children = 20
pm.start_servers = 2
pm.min_spare_servers = 1
pm.max_spare_servers = 3

clear_env = yes
catch_workers_output = yes
decorate_workers_output = no

access.log = /proc/self/fd/2

chdir = /srv/sites